# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://glacis:glacis@localhost:5432/glacis

# Ingest-side statement timeout (ms). If a raw_events insert exceeds this, we
# return 503 Retry-After so vendors can retry (§3.9 of README).
DB_INGEST_STATEMENT_TIMEOUT_MS=300

# Backpressure threshold: reject new webhooks with 503 when this many
# raw_events rows are in 'pending' state. (§3.7)
INGEST_BACKLOG_THRESHOLD=10000

# OpenAI
OPENAI_API_KEY=""
OPENAI_CLASSIFIER_MODEL=gpt-4.1-mini
OPENAI_EXTRACTOR_MODEL=gpt-4.1

# Worker concurrency and rate limits (§3.7)
WORKER_CONCURRENCY=8
LLM_GLOBAL_RATE_PER_SEC=50

# HMAC signature verification
HMAC_VERIFY_ENABLED=false

# Per-vendor secret env vars referenced from src/vendors.py
# Example:
# MAERSK_SECRET=replace-me
# FEDEX_SECRET=replace-me
